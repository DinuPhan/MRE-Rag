# ==========================================
# MRE-Rag Environment Configuration
# ==========================================

# ------------------------------------------
# 1. Generative LLM Provider (Contextual AI)
# ------------------------------------------
# Decide the LLM used for extracting logical summaries of isolated code snippets (Hybrid Partitioning).
# Valid Options: GEMINI, INHOUSE
# Behavior if GEMINI: Uses Google's Gemini-1.5/2.5 flash models via their native SDK.
# Behavior if INHOUSE: Uses httpx to send POST requests containing OpenAI-compatible `{model, messages, temperature}` payloads.
LLM_PROVIDER=GEMINI

# Gemini GenAI Configuration (Required if LLM_PROVIDER=GEMINI)
GEMINI_API_KEY=your_gemini_api_key_here

# In-House GenAI Configuration (Required if LLM_PROVIDER=INHOUSE)
INHOUSE_LLM_BASE_URL=http://your-inhouse-server:8000/api/openai/v1/chat/completions
INHOUSE_LLM_API_KEY=optional_auth_token
INHOUSE_LLM_MODEL=meta-llama-3-8b-instruct

# ------------------------------------------
# 2. Embedding Engine Selection
# ------------------------------------------
# Determines how raw text is vectorized before being inserted into Qdrant.
# Valid Options: GEMINI, OPENAI, INHOUSE
EMBEDDING_PROVIDER=GEMINI

# OpenAI Embeddings Configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# In-House Embeddings Configuration
# Behavior: Expects standard OpenAI-compatible `{"input": ["string"], "model": "target"}` payload structure.
INHOUSE_BASE_URL=http://your-inhouse-server:8000/api/openai/v1/embeddings
INHOUSE_API_KEY=optional_auth_token
INHOUSE_EMBEDDING_MODEL=in-house-embedding-default
INHOUSE_EMBEDDING_DIMENSION=512

# ------------------------------------------
# 3. Two-Stage Retrieval (Reranker)
# ------------------------------------------
# Determines whether an ultra-precise cross-encoder pass is executed AFTER the vector similarity search.
# Valid Options: NONE, INHOUSE
# Behavior if NONE: Raw Bi-Encoder cosine similarity results are returned immediately. (Fastest, default).
# Behavior if INHOUSE: Fetches 10x the limit from Qdrant, passes the [Query, Document] pairs to the 
# cross-encoder endpoint for deep semantic sorting, and discards the less relevant pairs. (Slightly slower, Highly accurate).
RERANKER_PROVIDER=NONE
INHOUSE_RERANKER_BASE_URL=http://your-inhouse-server:8000/api/v1/cross_encoder/score
INHOUSE_RERANKER_API_KEY=optional_auth_token
INHOUSE_RERANKER_MODEL=inhouse-reranker-default

# ------------------------------------------
# 4. Qdrant Database Configuration
# ------------------------------------------
# Vector database connection. If left empty, will fallback to a local in-memory instance for testing.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY= # Leave empty for local docker instances without auth

# ------------------------------------------
# 5. MCP / FastAPI Server Configuration
# ------------------------------------------
HOST=0.0.0.0
PORT=8051

# Output directory for llms.txt crawls and script exports.
OUTPUT_DIR=output

# ------------------------------------------
# 6. Neo4j Graph DB Configuration
# ------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Determines how local codebases are parsed and mapped into Neo4j via tree-sitter.
# Options: INCREMENTAL, FULL
# Behavior if FULL: Drops existing repository nodes and reconstructs the full AST tree on every run.
# Behavior if INCREMENTAL: Performs a `git diff --name-only` against the last commit hash. Only parses files that changed perfectly saving massive overhead on larger codebases.
NEO4J_INDEXING_STRATEGY=INCREMENTAL
